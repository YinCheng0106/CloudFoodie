# 環境變數範本 — 複製為 .env 後填入你自己的金鑰
#   cp .env.example .env
# .env 已列入 .gitignore,不會被提交,請勿把真實金鑰寫進 .env.example。
#
# 三個皆為「選用」,未設定時功能會自動降級(地圖改用免金鑰內嵌、AI 摘要隱藏)。

# Google Maps 金鑰(Maps JavaScript API + Places API + Maps Embed API)
GOOGLE_MAPS_API_KEY=

# Gemini AI 金鑰(Google AI Studio 取得,免費額度)
GEMINI_API_KEY=

# 指定 Gemini 模型,可省略;預設 gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
